########################################
# CI: release workflow kept out of repo (local copy allowed; not tracked)
########################################
.github/workflows/release.yml


########################################
# OS / Editor
########################################
.DS_Store
Thumbs.db

# Cursor IDE (entire project metadata; do not commit if you want it local-only)
.cursor/

.vscode/*
!.vscode/extensions.json
.idea/

*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?


########################################
# Logs
########################################
logs/
**/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*


########################################
# Env / Secrets
########################################
.env
.env.*
**/.env
**/.env.*
assets/oauth/google_oauth_client.json


########################################
# Node / Package managers
########################################
node_modules/
**/node_modules/
*.local


########################################
# Build outputs (Vite/React/SSR/etc.)
########################################
dist/
**/dist/
dist-ssr/
**/dist-ssr/


########################################
# Next.js
########################################
.next/
**/.next/


########################################
# Electron / Desktop builds & releases
########################################
release/
**/release/
out/
**/out/
win-unpacked/
**/win-unpacked/

*.exe
*.msi
*.dmg
*.pkg
*.AppImage
*.asar


########################################
# Archives
########################################
*.zip
*.7z
*.rar


########################################
# Test artifacts
########################################
test-results/


########################################
# Your pipeline outputs (DO NOT COMMIT)
########################################
yt_pipeline/outputs/
yt_pipeline/outputs/**

# Optional: ignore similar output folders anywhere
**/outputs/
**/exports/
**/transcripts/
**/reports/
**/audio/

# Personal notes (do not use broad *.md — breaks README, CONTRIBUTING, etc.)
NOTES.md
TODO_PERSONAL.md
**/personal-notes/

