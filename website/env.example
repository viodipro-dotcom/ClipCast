# Supabase (required for auth / account)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Site URL (for OAuth redirects and billing success/cancel URLs)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Stripe (optional – billing works without these; shows "Billing not configured")
# -----------------------------------------------------------------------------
# Publishable key (client-side; safe to expose)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Secret key (server-only; never expose to client)
STRIPE_SECRET_KEY=

# Webhook signing secret (for future Stripe webhooks)
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs (monthly subscription prices from Stripe Dashboard)
# Create products/prices in Stripe, then paste the price_xxx IDs here.
STRIPE_PRICE_ID_BASIC=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_PRO_PLUS=
